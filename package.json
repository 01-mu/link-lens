{
  "name": "linklens",
  "private": true,
  "packageManager": "bun@1.2.10",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "bun run --filter @linklens/web dev",
    "dev:api": "bun run --filter @linklens/api dev",
    "build": "bun run --workspaces --if-present build",
    "test": "bun run --workspaces --if-present typecheck"
  }
}
